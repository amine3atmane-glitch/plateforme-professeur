rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.email == 'aminens21@gmail.com';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAuthorized() {
      return isSuperAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/authorized_users/$(request.auth.token.email)));
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Rules for Teachers Platform ---

    // 1. Profiles and Details
    match /profiles/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /teacher_details/{userId} {
      allow read, write: if isOwner(userId) || isSuperAdmin();
    }

    // 2. Timetable and Licenses
    match /timetable_sessions/{sessionId} {
      allow read, write: if isOwner(incoming() != null ? (incoming().get('user_id', '')) : (existing().get('user_id', ''))) || isSuperAdmin();
    }

    match /licenses/{licenseId} {
      allow read, write: if isOwner(incoming() != null ? (incoming().get('user_id', '')) : (existing().get('user_id', ''))) || isSuperAdmin();
    }

    // 3. Shared Sync Collection (The Bridge)
    match /teachers/{teacherId} {
      // Inspector can only read teachers linked to their email
      allow read: if isAuthorized() && (isSuperAdmin() || resource.data.inspector_email == request.auth.token.email);
      // Teacher can create and update their public record
      allow create, update: if isOwner(teacherId);
      allow delete: if isSuperAdmin();
    }

    // 4. Access Code and Authorization
    match /authorized_users/{email} {
      // Allows teachers to check the code during linking
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (request.auth.token.email == email || isSuperAdmin());
      allow update: if isSignedIn() && request.auth.token.email == email && incoming().diff(existing()).affectedKeys().hasOnly(['accessCode']);
      allow create, delete: if isSuperAdmin();
    }

    // --- Backup & Inspector Logic ---
    match /settings/branding {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /backups/{userId} {
      allow get, delete: if isOwner(userId);
      allow create, update: if isOwner(userId);
      match /chunks/{chunkId} {
        allow list, get, create, update, delete: if isOwner(userId);
      }
    }

    match /users_data/{inspectorName} {
      allow read, write: if isSuperAdmin();
    }
  }
}
